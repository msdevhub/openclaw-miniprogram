@import "./tokens.wxss";

.shell-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: var(--color-surface);
}

.screen-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
}

.screen-panel--forward {
  animation: screenInForward 0.28s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.screen-panel--backward {
  animation: screenInBackward 0.28s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.screen {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.screen--onboarding {
  justify-content: space-between;
  padding: 0 40rpx 40rpx;
}

.onboarding-top {
  padding-top: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-mark {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-32);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-deep));
  box-shadow: var(--shadow-primary);
  margin-bottom: 48rpx;
}

.brand-mark__glyph {
  color: #FFFFFF;
  font-size: 76rpx;
  font-weight: 500;
}

.onboarding-title {
  font-size: 64rpx;
  line-height: 1.12;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.onboarding-subtitle {
  max-width: 540rpx;
  text-align: center;
  color: rgba(45, 52, 54, 0.6);
  font-size: 34rpx;
  line-height: 1.5;
}

.onboarding-hero {
  display: flex;
  justify-content: center;
  margin: 48rpx 0;
}

.onboarding-hero__image {
  width: 560rpx;
  height: 560rpx;
  border-radius: 80rpx;
  box-shadow: 0 30rpx 84rpx rgba(45, 52, 54, 0.14);
}

.onboarding-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.primary-button {
  height: 104rpx;
  border-radius: 48rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: var(--shadow-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.primary-button--save {
  margin-top: 20rpx;
}

.primary-button--inline {
  margin-top: 0;
}

.primary-button__label {
  font-size: 32rpx;
  font-weight: 400;
  color: #FFFFFF;
}

.screen-header {
  box-sizing: border-box;
  padding: 0 32rpx 18rpx;
  background: linear-gradient(180deg, rgba(248, 250, 251, 0.95), rgba(248, 250, 251, 0.82));
}

.screen-header--sticky {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.screen-header__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.screen-header__row--capsule-safe {
  box-sizing: border-box;
}

.screen-header--chat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border-bottom: 2rpx solid rgba(237, 242, 240, 0.82);
}

.nav-side-slot {
  flex-shrink: 0;
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

.nav-side-slot--end {
  justify-content: flex-end;
}

.screen-header__center {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.screen-header__title {
  font-size: 34rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.screen-title {
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 500;
  color: var(--color-text-primary);
}

.icon-button,
.header-icon-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-button {
  background: #FFFFFF;
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.header-icon-button--ghost {
  background: transparent;
}

.header-icon-button--spacer {
  opacity: 0;
  pointer-events: none;
}

.button-pressed {
  transform: scale(0.98);
  opacity: 0.92;
}

.search-field {
  height: 88rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-border);
  background: #FFFFFF;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 28rpx;
}

.search-field--lg {
  height: 104rpx;
  border-radius: 48rpx;
  margin-top: 32rpx;
}

.search-field__leading {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-field__input {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.screen-scroll {
  flex: 1;
  min-height: 0;
}

.screen-scroll--with-nav {
  padding-bottom: 148rpx;
}

.chat-list,
.dashboard-body,
.profile-body,
.search-body,
.preferences-body {
  padding: 0 32rpx 176rpx;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pairing-body {
  padding: 24rpx 32rpx 64rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.pairing-hero {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.pairing-chip {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(103, 184, 139, 0.12);
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-primary-deep);
}

.pairing-copy {
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(45, 52, 54, 0.58);
}

.pairing-readonly {
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: rgba(45, 52, 54, 0.6);
}

.pairing-note {
  padding: 28rpx 30rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.pairing-note__title {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.pairing-note__desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(45, 52, 54, 0.54);
}

.empty-state {
  margin-top: 120rpx;
  text-align: center;
  color: rgba(45, 52, 54, 0.42);
  font-size: 28rpx;
}

.chat-room-head {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.chat-room-head__title {
  font-size: 34rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.chat-room-head__status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.chat-room-head__status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
}

.chat-room-head__status-dot--connected {
  background: var(--color-primary);
}

.chat-room-head__status-dot--connecting,
.chat-room-head__status-dot--reconnecting {
  background: var(--color-orange);
}

.chat-room-head__status-dot--disconnected {
  background: var(--color-red);
}

.chat-room-head__status-text {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-primary);
}

.chat-room-head__status-text--connected {
  color: var(--color-primary);
}

.chat-room-head__status-text--connecting,
.chat-room-head__status-text--reconnecting {
  color: var(--color-orange);
}

.chat-room-head__status-text--disconnected {
  color: var(--color-red);
}

.chat-room-scroll {
  flex: 1;
  min-height: 0;
  padding-bottom: 0;
}

.chat-room-list {
  padding: 32rpx 32rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.chat-room-empty {
  margin: 80rpx 0 24rpx;
  padding: 40rpx 32rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.chat-room-empty__title {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.chat-room-empty__desc {
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(45, 52, 54, 0.5);
}

.message-end-anchor {
  height: 2rpx;
}

.thinking-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.thinking-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-deep));
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(103, 184, 139, 0.18);
}

.thinking-bubble {
  max-width: 78%;
  padding: 24rpx 30rpx;
  border-radius: 48rpx;
  border-top-left-radius: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.thinking-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.thinking-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(45, 52, 54, 0.3);
  animation: thinkingPulse 1.4s infinite ease-in-out;
}

.thinking-dot--2 {
  animation-delay: 0.18s;
}

.thinking-dot--3 {
  animation-delay: 0.36s;
}

.thinking-text {
  font-size: 26rpx;
  line-height: 1.5;
  color: rgba(45, 52, 54, 0.58);
}

.chat-room-input {
  padding: 0 24rpx 4rpx;
  background: linear-gradient(180deg, rgba(248, 250, 251, 0), rgba(248, 250, 251, 0.94) 26%, rgba(248, 250, 251, 1));
}

.chat-input-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-border);
  background: #FFFFFF;
  box-shadow: var(--shadow-floating);
}

.chat-input {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.chat-send {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-send--active {
  background: var(--color-primary);
  box-shadow: 0 16rpx 32rpx rgba(103, 184, 139, 0.24);
}

.slash-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.slash-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 32rpx;
}

.slash-item--pressed {
  background: rgba(45, 52, 54, 0.03);
}

.slash-item__icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.slash-item__copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.slash-item__label {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.slash-item__desc {
  font-size: 24rpx;
  color: rgba(45, 52, 54, 0.5);
}

.dashboard-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dashboard-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-head__title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.live-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--color-border);
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.metric-grid {
  display: flex;
  gap: 18rpx;
}

.metric-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.metric-card__label {
  font-size: 22rpx;
  color: rgba(45, 52, 54, 0.5);
}

.metric-card__value {
  font-size: 42rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.task-stack,
.checkpoint-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.task-item__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-item__label {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.task-item__status {
  font-size: 26rpx;
  color: rgba(45, 52, 54, 0.48);
}

.task-item__status--active {
  color: var(--color-primary);
}

.checkpoint-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
}

.checkpoint-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkpoint-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: rgba(91, 141, 239, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkpoint-name {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.checkpoint-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: rgba(45, 52, 54, 0.42);
}

.api-grid {
  display: flex;
  gap: 16rpx;
}

.api-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 22rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
}

.api-ping {
  position: relative;
  width: 22rpx;
  height: 22rpx;
}

.api-ping__pulse,
.api-ping__core {
  position: absolute;
  inset: 0;
  border-radius: 999rpx;
}

.api-ping__pulse {
  background: rgba(103, 184, 139, 0.34);
  animation: pulse 1.8s infinite;
}

.api-ping__core {
  width: 22rpx;
  height: 22rpx;
  background: var(--color-primary);
}

.api-card__name,
.api-card__latency {
  display: block;
}

.api-card__name {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.api-card__latency {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(45, 52, 54, 0.48);
}

.profile-body {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 18rpx 44rpx rgba(45, 52, 54, 0.16);
}

.profile-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-name {
  font-size: 42rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.profile-plan {
  font-size: 28rpx;
  color: rgba(45, 52, 54, 0.5);
}

.quota-card {
  padding: 32rpx;
  border-radius: 64rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-deep));
  color: #FFFFFF;
  box-shadow: var(--shadow-primary);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quota-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quota-label {
  font-size: 28rpx;
  opacity: 0.92;
}

.quota-value {
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 500;
}

.quota-value__unit {
  font-size: 30rpx;
  font-weight: 400;
  opacity: 0.84;
}

.quota-foot {
  align-self: flex-end;
  font-size: 22rpx;
  opacity: 0.82;
}

.settings-group {
  overflow: hidden;
  border-radius: 64rpx;
  border: 2rpx solid var(--color-border);
  background: #FFFFFF;
  box-shadow: var(--shadow-card);
}

.danger-button {
  height: 100rpx;
  border-radius: 48rpx;
  background: rgba(225, 91, 100, 0.08);
  color: var(--color-red);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 400;
}

.search-body {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}

.search-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-caption {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  color: rgba(45, 52, 54, 0.48);
}

.section-caption--with-icon {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.search-history {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.search-history__item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.search-history__item--pressed {
  transform: scale(0.98);
}

.search-history__label {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.search-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.search-filter {
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-border);
  background: #FFFFFF;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.preferences-body {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding-top: 24rpx;
}

.preferences-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 48rpx;
  background: #FFFFFF;
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(45, 52, 54, 0.72);
}

.form-input,
.picker-field,
.form-textarea {
  width: 100%;
  border-radius: 32rpx;
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
  color: var(--color-text-primary);
  font-size: 30rpx;
}

.form-input,
.picker-field {
  height: 88rpx;
  padding: 0 24rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-textarea {
  min-height: 160rpx;
  padding: 24rpx;
  line-height: 1.5;
}

.slider-head,
.slider-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.slider-value {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-primary);
}

.profile-connection-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.profile-connection-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.profile-connection-row--stacked {
  align-items: flex-start;
  flex-direction: column;
}

.profile-connection-label {
  font-size: 24rpx;
  color: rgba(45, 52, 54, 0.48);
}

.profile-connection-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 26rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.profile-connection-value--mono {
  font-family: SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: 22rpx;
  text-align: left;
  line-height: 1.6;
  word-break: break-all;
}

.profile-connection-value--connected {
  color: var(--color-primary);
}

.profile-connection-value--connecting,
.profile-connection-value--reconnecting {
  color: var(--color-orange);
}

.profile-connection-value--disconnected {
  color: var(--color-red);
}

.profile-notify-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-notify-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.profile-notify-desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(45, 52, 54, 0.52);
}

.slider-foot {
  font-size: 22rpx;
  color: rgba(45, 52, 54, 0.4);
}

@keyframes screenInForward {
  from {
    opacity: 0;
    transform: translate3d(40rpx, 0, 0);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes screenInBackward {
  from {
    opacity: 0;
    transform: translate3d(-40rpx, 0, 0);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes pulse {
  0% {
    opacity: 0.4;
    transform: scale(1);
  }
  70% {
    opacity: 0;
    transform: scale(2.4);
  }
  100% {
    opacity: 0;
    transform: scale(2.4);
  }
}

@keyframes thinkingPulse {
  0%, 80%, 100% {
    opacity: 0.36;
    transform: scale(0.85);
  }
  40% {
    opacity: 1;
    transform: scale(1);
  }
}
