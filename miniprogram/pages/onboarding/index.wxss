@import "../../theme/page-shell.wxss";

.onboarding-carousel {
  height: 480rpx;
  margin: 40rpx 0 20rpx;
}

.slide-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 48rpx 0;
}

.slide-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.slide-icon__emoji {
  font-size: 64rpx;
}

.slide-card__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.slide-card__desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
  max-width: 560rpx;
}

.onboarding-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
}

.onboarding-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(45, 52, 54, 0.15);
  transition: all 0.3s;
}

.onboarding-dot--active {
  width: 48rpx;
  background: var(--color-primary);
}
