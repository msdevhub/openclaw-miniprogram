<view class="shell-page">
  <view class="screen">
    <view class="screen-header screen-header--chat" style="padding-top: {{navBarPaddingTop}}px; min-height: {{navBarHeight}}px;">
      <view class="nav-side-slot" style="width: {{navSideSlotWidth}}px;">
        <view class="header-icon-button" bindtap="handleBack" hover-class="button-pressed">
          <oc-icon name="chevron-left" tone="dark" size="42rpx" />
        </view>
      </view>
      <view class="screen-header__center">
        <text class="screen-header__title">Pairing</text>
      </view>
      <view class="nav-side-slot nav-side-slot--end" style="width: {{navSideSlotWidth}}px;"></view>
    </view>

    <scroll-view class="screen-scroll" scroll-y>
      <view class="pairing-body">
        <view class="pairing-hero">
          <view class="pairing-chip">
            <oc-icon name="server" tone="green" size="28rpx" />
            <text>OpenClaw Pairing</text>
          </view>
          <text class="screen-title">Connect Workspace</text>
          <text class="pairing-copy">
            Set your Generic Channel endpoint first. After that, the agent list will reflect the paired OpenClaw workspace.
          </text>
        </view>

        <view class="form-card">
          <view class="form-field">
            <text class="form-label">Display Name</text>
            <input class="form-input" value="{{preferenceForm.displayName}}" data-field="displayName" bindinput="handleInput" />
          </view>

          <view class="form-field">
            <text class="form-label">Generic Channel WS URL</text>
            <input
              class="form-input"
              value="{{preferenceForm.genericChannelUrl}}"
              data-field="genericChannelUrl"
              bindinput="handleInput"
              placeholder="ws://host:18080/ws"
              placeholder-style="color: rgba(45, 52, 54, 0.35);"
            />
          </view>

          <view class="form-field">
            <text class="form-label">Auth Token <text class="form-label--hint">(optional)</text></text>
            <input
              class="form-input"
              value="{{preferenceForm.token}}"
              data-field="token"
              bindinput="handleInput"
              placeholder="gc_user_xxxxxxxxx"
              placeholder-style="color: rgba(45, 52, 54, 0.35);"
            />
          </view>

          <view class="form-field">
            <text class="form-label">Chat ID <text class="form-label--hint">(token auth: must match binding)</text></text>
            <input
              class="form-input"
              value="{{preferenceForm.chatId}}"
              data-field="chatId"
              bindinput="handleInput"
              placeholder="gc-test-main"
              placeholder-style="color: rgba(45, 52, 54, 0.35);"
            />
          </view>

          <view class="form-field">
            <text class="form-label">Sender ID <text class="form-label--hint">(token auth: must match binding)</text></text>
            <input
              class="form-input"
              value="{{preferenceForm.senderId}}"
              data-field="senderId"
              bindinput="handleInput"
              placeholder="gc-test-main"
              placeholder-style="color: rgba(45, 52, 54, 0.35);"
            />
          </view>
        </view>

        <view class="pairing-note">
          <text class="pairing-note__title">Current test environment</text>
          <text class="pairing-note__desc">Use your own endpoint here. For real-device WeChat tests, switch to a valid `wss://` domain.</text>
        </view>

        <view class="primary-button primary-button--save" bindtap="handlePairConnection" hover-class="button-pressed">
          <text class="primary-button__label">Pair and Continue</text>
          <oc-icon name="arrow-right" tone="white" size="32rpx" />
        </view>
      </view>
    </scroll-view>
  </view>
</view>
