@import "../../theme/page-shell.wxss";

/* Pairing tabs */
.pairing-tabs {
  display: flex;
  background: var(--color-surface);
  border-radius: var(--radius-pill);
  padding: 4rpx;
  border: 2rpx solid var(--color-border);
  margin-bottom: 24rpx;
}

.pairing-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-muted);
}

.pairing-tab--active {
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: var(--shadow-card);
}

.pairing-error {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #E15B64;
  margin-bottom: 16rpx;
}

.pairing-url-hint {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
  margin: 12rpx 0 20rpx;
}

.form-input-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.form-input--with-action {
  flex: 1;
}

.form-input-action {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-12);
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  flex-shrink: 0;
}

.form-input-action__text {
  font-size: 32rpx;
}

/* QR card */
.pairing-qr-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.pairing-qr-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.pairing-qr-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  text-align: center;
}
