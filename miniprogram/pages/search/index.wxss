@import "../../theme/page-shell.wxss";

/* Search results */
.search-results {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.search-result-item {
  background: var(--color-surface);
  padding: 24rpx;
  border-radius: var(--radius-16);
  border: 2rpx solid var(--color-border);
}

.search-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.search-result-sender {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.search-result-time {
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.search-result-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.search-result-count {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 24rpx;
}

.search-empty {
  text-align: center;
  padding: 80rpx 0;
}

.search-empty__text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.search-empty-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.search-empty-hero__text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
