@import "./theme/tokens.wxss";

page {
  min-height: 100%;
  background: var(--color-surface);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view,
image {
  box-sizing: border-box;
}

image {
  display: block;
}
