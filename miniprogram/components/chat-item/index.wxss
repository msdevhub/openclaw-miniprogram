@import "../../theme/tokens.wxss";

.chat-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: var(--radius-24);
  background: var(--color-card);
  border: 2rpx solid rgba(237, 242, 240, 0.7);
  box-shadow: var(--shadow-card);
  animation: cardIn 0.32s cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.chat-item--pressed {
  transform: scale(0.98);
}

.chat-avatar {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
}

.chat-avatar__single {
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 26rpx rgba(45, 52, 54, 0.12);
}

.chat-avatar__status {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  width: 26rpx;
  height: 26rpx;
  border-radius: 999rpx;
  border: 4rpx solid #FFFFFF;
  background: var(--color-primary);
}

.chat-avatar__group {
  position: relative;
  width: 112rpx;
  height: 112rpx;
}

.chat-avatar__group-first,
.chat-avatar__group-second {
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 10rpx 22rpx rgba(45, 52, 54, 0.12);
}

.chat-avatar__group-first {
  top: 0;
  right: 0;
}

.chat-avatar__group-second {
  left: 0;
  bottom: 0;
}

.chat-avatar__group-count {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  border: 4rpx solid #FFFFFF;
  background: var(--color-border);
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
}

.chat-body {
  flex: 1;
  min-width: 0;
}

.chat-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.chat-title {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.chat-name {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.chat-detail {
  font-size: 22rpx;
  color: rgba(45, 52, 54, 0.42);
}

.chat-badge,
.chat-time {
  flex-shrink: 0;
  font-size: 20rpx;
  color: rgba(45, 52, 54, 0.48);
}

.chat-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(103, 184, 139, 0.12);
  color: var(--color-primary-deep);
  font-weight: 400;
}

.chat-message {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  color: rgba(45, 52, 54, 0.6);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.chat-unread {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 500;
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
