@import "../../theme/page-shell.wxss";

.profile-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #67B88B, #4A9A70);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(103, 184, 139, 0.3);
  border: 4rpx solid #fff;
}

.profile-avatar-placeholder__text {
  font-size: 56rpx;
}

.section-caption--between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-caption__left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.icon-button--small {
  padding: 8rpx;
}

.profile-server-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-server-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: var(--color-surface);
  border-radius: var(--radius-16);
  border: 2rpx solid var(--color-border);
}

.profile-server-item--active {
  border-color: var(--color-primary);
}

.profile-server-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  color: var(--color-text-muted);
}

.profile-server-icon--active {
  background: var(--color-primary);
  color: #fff;
}

.profile-server-info {
  flex: 1;
  min-width: 0;
}

.profile-server-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-server-url {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

.profile-server-delete {
  padding: 12rpx;
  flex-shrink: 0;
}

.profile-server-delete__text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.profile-server-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.profile-server-empty__text {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-bottom: 20rpx;
}

.primary-button--compact {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
}
