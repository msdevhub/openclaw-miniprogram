@import "../../theme/tokens.wxss";

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.setting-row--pressed {
  background: rgba(45, 52, 54, 0.03);
}

.setting-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.setting-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
}

.setting-label {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.setting-value {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-value__text {
  font-size: 28rpx;
  color: rgba(45, 52, 54, 0.4);
}

.setting-switch {
  width: 84rpx;
  height: 48rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: var(--color-border);
  transition: background 0.22s ease;
}

.setting-switch--active {
  background: var(--color-primary);
}

.setting-switch__thumb {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 16rpx rgba(45, 52, 54, 0.14);
  transition: transform 0.22s ease;
}

.setting-switch__thumb--active {
  transform: translateX(36rpx);
}
