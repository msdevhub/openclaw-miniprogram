@import "../../theme/tokens.wxss";

.progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: var(--color-border);
}

.progress-track--compact {
  height: 8rpx;
}

.progress-value {
  height: 100%;
  border-radius: 999rpx;
  animation: progressGrow 0.8s ease-out both;
}

@keyframes progressGrow {
  from {
    transform: scaleX(0);
    transform-origin: left center;
  }
  to {
    transform: scaleX(1);
    transform-origin: left center;
  }
}
